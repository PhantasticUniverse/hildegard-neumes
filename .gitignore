# Font build artifacts — produced by scripts/build-font.sh from src/*.ufo.
# Rebuilt from the UFO on demand; released via `gh release create` as tag
# assets rather than tracked in git.
build/*.otf
build/*.woff
build/*.woff2
build/*.ttf

# check-generated justfile recipe output directory
build/_check/

# FontForge source-of-drawing file. UFO3 at src/hildegard-neumes.ufo/ is
# authoritative; the SFD is a FontForge-native duplicate that drifts from
# the UFO when the user edits either side. Keep it locally if convenient
# but don't ship it as project state.
src/*.sfd
*.sfd~
*.sfdir.bak
src/*.bak

# Python virtual environments (for scripts/)
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Node artifacts (none expected, but safe)
node_modules/

# Claude Code per-user settings (local allowlist; personal, not project state)
.claude/settings.local.json
